{
  "name": "chrome-debugger",
  "title": "Browser DevTools",
  "version": "1.0.0",
  "description": "Native browser automation and debugging via Chrome DevTools Protocol. Launch a browser, inspect DOM, execute JavaScript, capture network traffic, take screenshots, and more — all through CLI commands.",
  "icon": "icon.svg",
  "type": "standard",
  "engines": {
    "renre-kit": ">=0.0.1",
    "extension-sdk": ">=0.0.1"
  },
  "main": "dist/index.js",
  "commands": {
    "launch": {
      "handler": "dist/commands/launch.js",
      "description": "Launch a browser instance with DevTools Protocol enabled"
    },
    "close": {
      "handler": "dist/commands/close.js",
      "description": "Close the browser and clean up"
    },
    "navigate": {
      "handler": "dist/commands/navigate.js",
      "description": "Navigate the current tab to a URL"
    },
    "tabs": {
      "handler": "dist/commands/tabs.js",
      "description": "List all open browser tabs"
    },
    "tab": {
      "handler": "dist/commands/tab.js",
      "description": "Switch to a specific tab by index"
    },
    "dom": {
      "handler": "dist/commands/dom.js",
      "description": "Get DOM tree or subtree as HTML"
    },
    "select": {
      "handler": "dist/commands/select.js",
      "description": "Query elements by CSS selector and return summary"
    },
    "click": {
      "handler": "dist/commands/click.js",
      "description": "Click an element by CSS selector"
    },
    "type": {
      "handler": "dist/commands/type.js",
      "description": "Type text into an input element"
    },
    "eval": {
      "handler": "dist/commands/eval.js",
      "description": "Execute JavaScript in the page context"
    },
    "network": {
      "handler": "dist/commands/network.js",
      "description": "Show captured network requests"
    },
    "console": {
      "handler": "dist/commands/console.js",
      "description": "Show captured console messages"
    },
    "screenshot": {
      "handler": "dist/commands/screenshot.js",
      "description": "Take a screenshot of the page or an element"
    },
    "cookies": {
      "handler": "dist/commands/cookies.js",
      "description": "List browser cookies"
    },
    "storage": {
      "handler": "dist/commands/storage.js",
      "description": "Show localStorage or sessionStorage contents"
    },
    "styles": {
      "handler": "dist/commands/styles.js",
      "description": "Get computed styles for an element"
    },
    "a11y": {
      "handler": "dist/commands/a11y.js",
      "description": "Get the accessibility tree"
    },
    "performance": {
      "handler": "dist/commands/performance.js",
      "description": "Get performance metrics and Core Web Vitals"
    },
    "inspect": {
      "handler": "dist/commands/inspect.js",
      "description": "Activate element picker — user clicks an element in the browser, agent gets full details"
    },
    "selected": {
      "handler": "dist/commands/selected.js",
      "description": "Get details about the last inspected/selected element"
    },
    "highlight": {
      "handler": "dist/commands/highlight.js",
      "description": "Highlight an element in the browser by CSS selector"
    },
    "status": {
      "handler": "dist/commands/status.js",
      "description": "Get browser session status with session recovery"
    },
    "heartbeat": {
      "handler": "dist/commands/heartbeat.js",
      "description": "Update browser session heartbeat timestamp"
    },
    "chrome-check": {
      "handler": "dist/commands/chrome-check.js",
      "description": "Check if Chrome/Chromium is installed"
    },
    "chrome-install": {
      "handler": "dist/commands/chrome-install.js",
      "description": "Download and install Chromium via Puppeteer"
    },
    "screenshot-list": {
      "handler": "dist/commands/screenshot-list.js",
      "description": "List saved screenshots with metadata"
    },
    "screenshot-read": {
      "handler": "dist/commands/screenshot-read.js",
      "description": "Read a screenshot as base64 data URL"
    },
    "screenshot-delete": {
      "handler": "dist/commands/screenshot-delete.js",
      "description": "Delete a saved screenshot"
    },
    "clear-logs": {
      "handler": "dist/commands/clear-logs.js",
      "description": "Clear console and network log files"
    }
  },
  "config": {
    "schema": {
      "headless": {
        "type": "boolean",
        "description": "Launch browser in headless mode",
        "secret": false,
        "default": false
      },
      "port": {
        "type": "number",
        "description": "Chrome remote debugging port",
        "secret": false,
        "default": 9222
      }
    }
  },
  "ui": {
    "panels": [
      {
        "id": "overview",
        "title": "Overview",
        "entry": "dist/panels/overview.js"
      },
      {
        "id": "screenshots",
        "title": "Screenshots",
        "entry": "dist/panels/screenshots.js"
      },
      {
        "id": "logs",
        "title": "Logs",
        "entry": "dist/panels/logs.js"
      }
    ]
  },
  "agent": {
    "skills": [
      { "name": "browser-control", "path": "agent/skills/browser-control" },
      { "name": "dom-inspection", "path": "agent/skills/dom-inspection" },
      { "name": "javascript-execution", "path": "agent/skills/javascript-execution" },
      { "name": "network-analysis", "path": "agent/skills/network-analysis" },
      { "name": "browser-screenshot", "path": "agent/skills/browser-screenshot" },
      { "name": "element-picker", "path": "agent/skills/element-picker" }
    ]
  }
}

{
  "name": "hello-world",
  "title": "Hello World",
  "version": "1.0.0",
  "description": "A simple hello world extension for RenreKit",
  "icon": "wave",
  "type": "standard",
  "engines": {
    "renre-kit": ">=0.0.1",
    "extension-sdk": ">=0.0.1"
  },
  "main": "dist/index.js",
  "commands": {
    "greet": {
      "handler": "dist/commands/greet.js",
      "description": "Greet the user with a friendly message"
    },
    "info": {
      "handler": "dist/commands/info.js",
      "description": "Show extension info"
    }
  },
  "config": {
    "schema": {
      "companyName": {
        "type": "string",
        "description": "Company or team name displayed in greetings",
        "secret": false,
        "default": "RenreKit"
      },
      "apiToken": {
        "type": "string",
        "description": "API token for external service integration",
        "secret": true,
        "vaultHint": "hello-world.apiToken"
      }
    }
  },
  "ui": {
    "panels": [
      {
        "id": "hello-panel",
        "title": "Hello World",
        "entry": "dist/panel.js"
      },
      {
        "id": "settings-panel",
        "title": "Settings",
        "entry": "dist/settings-panel.js"
      },
      {
        "id": "analytics-panel",
        "title": "Analytics",
        "entry": "dist/analytics-panel.js"
      }
    ],
    "widgets": [
      {
        "id": "status-widget",
        "title": "Hello Status",
        "entry": "dist/status-widget.js",
        "defaultSize": { "w": 4, "h": 2 },
        "minSize": { "w": 3, "h": 2 },
        "maxSize": { "w": 6, "h": 4 }
      }
    ]
  },
  "agent": {
    "skills": [
      { "name": "greet", "path": "agent/skills/greet/SKILL.md" },
      { "name": "info", "path": "agent/skills/info/SKILL.md" }
    ],
    "prompts": ["agent/prompts/greeting-style.prompt.md"],
    "context": ["agent/context/extension-docs.context.md"],
    "hooks": ["agent/hooks/greeting-hooks.json"]
  }
}

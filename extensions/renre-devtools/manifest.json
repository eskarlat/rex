{
  "name": "renre-devtools",
  "title": "Browser Devtools",
  "version": "1.0.0",
  "description": "Browser automation and debugging via Puppeteer MCP server. Launch a headed browser, inspect tabs, take screenshots, execute JavaScript, and interact with web pages.",
  "icon": "icon.svg",
  "type": "mcp",
  "engines": {
    "renre-kit": ">=0.0.1",
    "extension-sdk": ">=0.0.1"
  },
  "main": "dist/index.js",
  "commands": {
    "status": {
      "handler": "dist/commands/status.js",
      "description": "Show browser MCP server status and available tools"
    }
  },
  "mcp": {
    "transport": "stdio",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-puppeteer"]
  },
  "config": {
    "schema": {}
  },
  "ui": {
    "panels": [
      {
        "id": "browser-panel",
        "title": "Browser Devtools",
        "entry": "dist/panel.js"
      }
    ],
    "widgets": [
      {
        "id": "browser-widget",
        "title": "Browser Status",
        "entry": "dist/browser-widget.js",
        "defaultSize": { "w": 4, "h": 2 },
        "minSize": { "w": 3, "h": 2 },
        "maxSize": { "w": 6, "h": 4 }
      }
    ]
  },
  "agent": {
    "skills": [
      { "name": "browser-navigate", "path": "agent/skills/browser-navigate" },
      { "name": "browser-inspect", "path": "agent/skills/browser-inspect" },
      { "name": "browser-screenshot", "path": "agent/skills/browser-screenshot" }
    ]
  }
}

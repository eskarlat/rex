{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"]
    },
    "test:coverage": {
      "dependsOn": ["build"]
    },
    "lint": {},
    "lint:duplication": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "validate": {
      "dependsOn": ["lint", "typecheck", "test:coverage", "lint:duplication"]
    }
  }
}

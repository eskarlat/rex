{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "exclude": ["types", "enumMembers"],
  "workspaces": {
    "packages/cli": {
      "ignore": ["tsup.config.ts", "vitest.config.ts"],
      "tsup": false,
      "vitest": false
    },
    "packages/shared": {},
    "packages/extension-sdk": {
      "ignore": ["src/components/ui/**"]
    },
    "packages/server": {},
    "packages/ui": {
      "ignore": ["src/components/ui/**", "e2e/**"]
    },
    "packages/create-renre-extension": {},
    "extensions/hello-world": {
      "entry": [
        "src/commands/greet.ts",
        "src/commands/info.ts",
        "src/ui/panel.tsx",
        "src/ui/settings-panel.tsx",
        "src/ui/analytics-panel.tsx",
        "src/ui/status-widget.tsx"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "extensions/context7-mcp": {
      "entry": [
        "src/commands/status.ts",
        "src/ui/panel.tsx",
        "src/ui/status-widget.tsx"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "extensions/figma-mcp": {
      "entry": [
        "src/commands/status.ts",
        "src/ui/panel.tsx",
        "src/ui/status-widget.tsx"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "extensions/renre-atlassian": {
      "entry": [
        "src/commands/**/*.ts",
        "src/ui/panel.tsx",
        "src/ui/my-tasks-widget.tsx",
        "src/ui/comments-widget.tsx",
        "src/ui/confluence-updates-widget.tsx"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "extensions/miro-mcp": {
      "entry": [
        "src/server.ts",
        "src/commands/status.ts",
        "src/ui/panel.tsx",
        "src/ui/status-widget.tsx"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "extensions/github-mcp": {
      "entry": [
        "src/commands/status.ts",
        "src/ui/panel.tsx",
        "src/ui/status-widget.tsx"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "extensions/chrome-debugger": {
      "entry": [
        "src/commands/status.ts",
        "src/ui/panel.tsx",
        "src/ui/browser-widget.tsx"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignoreDependencies": [
    "@vitest/coverage-istanbul",
    "pino-pretty",
    "@radix-ui/*",
    "@hookform/resolvers"
  ]
}

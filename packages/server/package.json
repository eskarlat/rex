{
  "name": "@renre-kit/server",
  "version": "0.0.1",
  "description": "RenreKit dashboard server — Fastify REST + WebSocket",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:duplication": "jscpd src/ --config ../../.jscpd.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@renre-kit/cli": "workspace:*",
    "croner": "^10.0.1",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/semver": "^7.5.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-istanbul": "^2.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-sonarjs": "^2.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}

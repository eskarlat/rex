{
  "name": "@renre-kit/cli",
  "version": "0.0.1",
  "description": "RenreKit CLI — lightweight plugin-driven development CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/core/types/index.js",
      "types": "./dist/core/types/index.d.ts"
    },
    "./lib": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    }
  },
  "bin": {
    "renre-kit": "./bin/renre-kit.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts --ignore-pattern '**/*.test.ts'",
    "lint:duplication": "jscpd src/ --config ../../.jscpd.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "better-sqlite3": "^11.7.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "semver": "^7.6.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@renre-kit/extension-sdk": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/fs-extra": "^11.0.4",
    "@types/semver": "^7.5.0",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-istanbul": "^2.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-sonarjs": "^2.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}

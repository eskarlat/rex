{
  "name": "create-renre-extension",
  "version": "0.0.1",
  "description": "Scaffolding tool for creating RenreKit extensions",
  "type": "module",
  "bin": {
    "create-renre-extension": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:duplication": "jscpd src/ --config ../../.jscpd.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-istanbul": "^2.1.0",
    "tsup": "^8.3.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint-plugin-sonarjs": "^2.0.0"
  }
}
